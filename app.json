{
  "expo": {
    "name": "Porto",
    "slug": "porto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "porto",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.porto.habit",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.app.porto.habit",
          "group.app.porto.habit"
        ]
      }
    },
    "android": {
      "package": "app.porto.habit",
      "adaptiveIcon": {
        "backgroundColor": "#FF4D6D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140,
          "backgroundColor": "#FF4D6D"
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.app.porto.habit",
          "widgets": [
            {
              "name": "PortoGoals",
              "supportedFamilies": [
                "systemMedium"
              ],
              "displayName": "Porto Goals",
              "description": "Urmărește goalurile tale",
              "contentMarginsDisabled": false
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PortoGoals",
              "label": "Porto Goals",
              "description": "Urmărește goalurile tale",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "app.porto.habit.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.app.porto.habit"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "7e219475-e5cb-484e-902c-4f19e90c7d52"
      }
    },
    "owner": "mircea21",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7e219475-e5cb-484e-902c-4f19e90c7d52"
    }
  }
}
